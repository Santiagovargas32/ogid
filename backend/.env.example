PORT=8080
NEWS_API_KEY=your_key_here
NEWS_API_BASE_URL=https://newsapi.org/v2
GNEWS_API_KEY=your_gnews_key_here
GNEWS_BASE_URL=https://gnews.io/api/v4
MEDIASTACK_API_KEY=your_mediastack_key_here
