{
  "name": "osint-backend",
  "version": "1.0.0",
  "description": "Local OSINT geopolitical intelligence dashboard backend",
  "private": true,
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:rss-lab": "node --watch --import ./scripts/rss-lab-setup.js server.js",
    "rss:probe": "node scripts/probe-rss.js",
    "rss:audit": "node scripts/audit-rss-catalog.js",
    "check": "node scripts/check-source.js",
    "test": "node --require ./tests/testSetup.cjs --test",
    "build": "npm run check"
  },
  "engines": {
    "node": ">=22.0.0 <27"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ws": "^8.21.0",
    "yahoo-finance2": "4.0.0"
  }
}
